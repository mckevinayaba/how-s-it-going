# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local to the repository.

# Payment provider keys (placeholder — wire up in a future phase)
VITE_PAYMENT_PUBLIC_KEY=

# Backend / API base URL (placeholder — wire up in a future phase)
VITE_API_BASE_URL=

# Form submission webhooks (see src/lib/submissions.ts).
# Point each at a Google Sheets webhook (Apps Script), Airtable REST
# endpoint, Supabase edge function, Zapier/Make webhook, or any CRM/email
# service that accepts a JSON POST. Leave a variable blank to keep that
# form's client-side confirmation working in simulated mode until a real
# destination is ready.
VITE_ORDER_REQUEST_WEBHOOK_URL=
VITE_SUPPORT_INQUIRY_WEBHOOK_URL=
VITE_CONTACT_WEBHOOK_URL=
VITE_ORDER_FOLLOW_UP_WEBHOOK_URL=
VITE_NEWSLETTER_WEBHOOK_URL=
